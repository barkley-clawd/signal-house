# Signal House local configuration example.
# Copy to .env for local development, or to ~/.config/clawd/signal-house.env
# for the daemon-style runtime described in README.md.

# Optional HTTP basic access protection. Leave password empty to disable.
SECRET_HOUSE_ACCESS_USERNAME=signal-house
SECRET_HOUSE_ACCESS_PASSWORD=

# GitHub API access. Token is required for issues, PRs, Actions, and checks.
SECRET_HOUSE_GITHUB_TOKEN=
SECRET_HOUSE_GITHUB_OWNER=
SECRET_HOUSE_GITHUB_REPO=

# Local git inputs. Use explicit repos, discovery roots, or both.
# Comma-separated paths are supported.
SECRET_HOUSE_GIT_REPOS=
SECRET_HOUSE_PROJECT_ROOTS=
SECRET_HOUSE_GIT_REPO_GLOBS=*
SECRET_HOUSE_GIT_DISCOVERY_MAX_DEPTH=3
SECRET_HOUSE_GIT_EXCLUDE=node_modules,dist,.next,.nuxt,.output

# OpenCode/OpenClaw session usage collection.
SECRET_HOUSE_SESSIONS_PERIOD_DAYS=30

# Background refresh loop.
SECRET_HOUSE_POLLER_ENABLED=false
SECRET_HOUSE_POLL_INTERVAL_SECONDS=300
SECRET_HOUSE_POLL_STARTUP_DELAY_SECONDS=5
SECRET_HOUSE_RUN_ON_STARTUP=true

# Collector/orchestrator defaults.
SECRET_HOUSE_COLLECT_CONCURRENCY=3
SECRET_HOUSE_COLLECT_LOOKBACK_DAYS=28
SECRET_HOUSE_STALE_THRESHOLD_DAYS=14

# Dashboard/runtime freshness and retention.
SECRET_HOUSE_STALE_THRESHOLD_MINUTES=15
SECRET_HOUSE_RETENTION_SNAPSHOTS_DAYS=30
SECRET_HOUSE_RETENTION_DAILY_METRICS_DAYS=90
SECRET_HOUSE_RETENTION_SESSIONS_DAYS=90
SECRET_HOUSE_RETENTION_WORKFLOW_RUNS_DAYS=90

# Attention queue: include issues and PRs from private GitHub repos.
# When false (default), private-repo items are hidden from the Attention Queue
# only; dashboard stats and other views are unaffected.
SECRET_HOUSE_SHOW_PRIVATE_REPO_ITEMS=false

# SQLite database directory. Defaults to .data when unset.
DB_DIR=.data
