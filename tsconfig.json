{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "strict": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "skipLibCheck": true,
    "types": ["jest", "node"]
  },
  "include": [
    "server/**/*.ts",
    "server/**/*.tsx",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "utils/**/*.ts",
    "types/**/*.ts"
  ]
}
